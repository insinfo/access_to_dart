  }) async {
    final rows = List<Map<String, dynamic>>.from(await db.table('{{tableRuntimeName}}').get());
    if (orderByColumn != null && orderByColumn.isNotEmpty) {
      rows.sort((left, right) {
        final leftValue = (left[orderByColumn] ?? left[labelColumn] ?? '').toString();
        final rightValue = (right[orderByColumn] ?? right[labelColumn] ?? '').toString();
        return leftValue.toLowerCase().compareTo(rightValue.toLowerCase());
      });
    }

    return rows
        .where((row) => row[valueColumn] != null)
        .take(limit)
        .map(
          (row) => <String, dynamic>{
            'value': row[valueColumn],
            'label': row[labelColumn] ?? row[valueColumn],
          },
        )
        .toList(growable: false);
  }

