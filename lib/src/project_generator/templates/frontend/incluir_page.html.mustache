{{=<% %>=}}
<div *ngIf="insideModal == false" class="page-header page-header-light shadow">
  <div class="page-header-content d-lg-flex">
    <h4 class="page-title mb-0">Módulo - <span class="fw-normal">Incluir <%namePascal%></span></h4>
  </div>
</div>

<div class="content">
  <div class="alert alert-info border-start border-info border-4 mb-3" *ngIf="validationHints.isNotEmpty">
    <strong>Regras migradas do formulario Access:</strong>
    <ul class="mb-0 mt-2">
      <li *ngFor="let hint of validationHints">{{ hint }}</li>
    </ul>
  </div>
  <div class="card">
    <div class="card-body">
      <form (ngSubmit)="salvar()" #formEntity="ngForm" novalidate>
        <div class="row">
<%#fields%>
          <div class="col-md-4 form-group mb-3">
            <label class="form-label"><%label%>:</label>
<%#isSingleSelect%>
            <select
              [ngModel]="readField('<%readKey%>')"
              (ngModelChange)="updateField('<%updateKey%>', $event)"
              ngControl="<%ngControl%>"
<%#isReadOnly%>
              disabled
<%/isReadOnly%>
<%#isRequired%>
              required
<%/isRequired%>
<%#title%>
              title="<%title%>"
<%/title%>
<%#selectSize%>
              size="<%selectSize%>"
<%/selectSize%>
              [class.is-invalid]="readFieldError('<%updateKey%>') != null"
              class="form-select">
              <option value="">Selecione <%label%></option>
<%#isDynamicSelect%>
              <option *ngFor="let option of lookupOptions('<%dynamicFieldKey%>')" [value]="option.value">{{ option.label }}</option>
<%/isDynamicSelect%>
<%#options%>
              <option value="<%value%>"><%label%></option>
<%/options%>
            </select>
<%/isSingleSelect%>
<%#isMultiValueSelect%>
            <div
              class="border rounded p-2"
<%#title%>
              title="<%title%>"
<%/title%>
              >
<%#isDynamicSelect%>
              <label class="form-check mb-1" *ngFor="let option of lookupOptions('<%dynamicFieldKey%>')">
                <input
                  class="form-check-input"
                  type="checkbox"
                  [checked]="isFieldOptionSelected('<%updateKey%>', option.value)"
                  (change)="toggleFieldSelection('<%updateKey%>', option.value, $event.target.checked)">
                <span class="form-check-label">{{ option.label }}</span>
              </label>
<%/isDynamicSelect%>
<%#options%>
              <label class="form-check mb-1">
                <input
                  class="form-check-input"
                  type="checkbox"
                  [checked]="isFieldOptionSelected('<%updateKey%>', '<%value%>')"
                  (change)="toggleFieldSelection('<%updateKey%>', '<%value%>', $event.target.checked)">
                <span class="form-check-label"><%label%></span>
              </label>
<%/options%>
            </div>
<%/isMultiValueSelect%>
<%#isCheckboxControl%>
            <div class="form-check pt-2">
              <input
                [ngModel]="readFieldBool('<%readKey%>')"
                (ngModelChange)="updateField('<%updateKey%>', $event)"
                ngControl="<%ngControl%>"
                type="checkbox"
<%#isReadOnly%>
                disabled
<%/isReadOnly%>
<%#title%>
                title="<%title%>"
<%/title%>
                class="form-check-input">
            </div>
<%/isCheckboxControl%>
<%#isTextAreaControl%>
            <textarea
              [ngModel]="readField('<%readKey%>')"
              (ngModelChange)="updateField('<%updateKey%>', $event)"
              ngControl="<%ngControl%>"
              rows="4"
<%#isReadOnly%>
              readonly
<%/isReadOnly%>
<%#isRequired%>
              required
<%/isRequired%>
<%#maxLength%>
              maxlength="<%maxLength%>"
<%/maxLength%>
<%#title%>
              title="<%title%>"
<%/title%>
              placeholder="<%label%>"
              [class.is-invalid]="readFieldError('<%updateKey%>') != null"
              class="form-control"></textarea>
<%/isTextAreaControl%>
<%#isAttachmentField%>
            <div
              class="border rounded bg-light-subtle px-3 py-2 small text-body-secondary"
<%#title%>
              title="<%title%>"
<%/title%>
              >
              <div class="fw-semibold text-body-emphasis mb-2">Subrecurso de anexos</div>
              <div *ngIf="hasAttachmentParentId() == false">
                Os anexos deste campo ficam disponiveis apos salvar o registro principal.
              </div>
              <div *ngIf="hasAttachmentParentId() && isAttachmentLoading('<%updateKey%>')">
                Carregando anexos...
              </div>
              <div *ngIf="attachmentError('<%updateKey%>') != null" class="text-danger">
                {{ attachmentError('<%updateKey%>') }}
              </div>
              <div *ngIf="hasAttachmentParentId() && attachmentRows('<%updateKey%>').isEmpty && attachmentError('<%updateKey%>') == null && isAttachmentLoading('<%updateKey%>') == false">
                Nenhum anexo vinculado.
              </div>
              <div *ngIf="attachmentRows('<%updateKey%>').isNotEmpty" class="d-grid gap-2">
                <div *ngFor="let row of attachmentRows('<%updateKey%>'); let idx = index" class="border rounded bg-white px-2 py-2">
                  <div class="d-flex justify-content-between align-items-start gap-2">
                    <div>
                      <div class="fw-semibold text-body-emphasis">Anexo {{ idx + 1 }}</div>
                      <div>{{ attachmentRowSummary('<%updateKey%>', row) }}</div>
                    </div>
                    <button
                      type="button"
                      class="btn btn-sm btn-outline-danger"
                      (click)="removeAttachment('<%updateKey%>', row['_attachmentOrdinal'])"
                      [disabled]="isAttachmentLoading('<%updateKey%>')">
                      Remover
                    </button>
                  </div>
                </div>
              </div>
              <div *ngIf="hasAttachmentParentId()" class="border rounded bg-white px-2 py-2 mt-2">
                <div class="fw-semibold text-body-emphasis mb-2">Novo anexo</div>
                <div class="d-grid gap-2">
                  <div *ngFor="let column of attachmentColumns('<%updateKey%>')">
                    <label class="form-label small mb-1">{{ attachmentColumnLabel(column) }}</label>
                    <input
                      *ngIf="attachmentColumnIsBinary(column)"
                      class="form-control form-control-sm"
                      type="file"
                      (change)="onAttachmentFileSelected('<%updateKey%>', attachmentColumnRuntimeName(column), $event)">
                    <div *ngIf="attachmentColumnIsBinary(column) && attachmentSelectedFileName('<%updateKey%>', attachmentColumnRuntimeName(column)) != null" class="form-text">
                      Arquivo selecionado: {{ attachmentSelectedFileName('<%updateKey%>', attachmentColumnRuntimeName(column)) }}
                    </div>
                    <input
                      *ngIf="attachmentColumnIsBinary(column) == false"
                      class="form-control form-control-sm"
                      type="text"
                      [ngModel]="attachmentDraftValue('<%updateKey%>', attachmentColumnRuntimeName(column))"
                      (ngModelChange)="updateAttachmentDraftField('<%updateKey%>', attachmentColumnRuntimeName(column), $event)"
                      ngControl="attachment_<%ngControl%>"
                      [placeholder]="attachmentColumnLabel(column)">
                  </div>
                </div>
                <div class="mt-2 text-end">
                  <button
                    type="button"
                    class="btn btn-sm btn-outline-primary"
                    (click)="createAttachment('<%updateKey%>')"
                    [disabled]="isAttachmentLoading('<%updateKey%>')">
                    Incluir anexo
                  </button>
                </div>
              </div>
              <div class="mt-2">
<%#attachmentTableName%>
                Origem materializada: <strong><%attachmentTableName%></strong>.
<%/attachmentTableName%>
<%#attachmentLinkColumn%>
                Vinculo interno: <strong><%attachmentLinkColumn%></strong>.
<%/attachmentLinkColumn%>
              </div>
            </div>
<%/isAttachmentField%>
<%#isPlainInput%>
            <input
              [ngModel]="readField('<%readKey%>')"
              (ngModelChange)="updateField('<%updateKey%>', $event)"
              ngControl="<%ngControl%>"
              type="<%inputType%>"
<%#isReadOnly%>
              readonly
<%/isReadOnly%>
<%#inputMode%>
              inputmode="<%inputMode%>"
<%/inputMode%>
<%#isRequired%>
              required
<%/isRequired%>
<%#maxLength%>
              maxlength="<%maxLength%>"
<%/maxLength%>
<%#title%>
              title="<%title%>"
<%/title%>
              placeholder="<%label%>"
              [class.is-invalid]="readFieldError('<%updateKey%>') != null"
              class="form-control">
<%/isPlainInput%>
            <div class="invalid-feedback d-block" *ngIf="readFieldError('<%updateKey%>') != null">
              {{ readFieldError('<%updateKey%>') }}
            </div>
          </div>
<%/fields%>
        </div>
        <div class="text-end mt-3">
          <button class="btn btn-primary btn-labeled btn-labeled-start" type="submit">
            <span class="btn-labeled-icon bg-black bg-opacity-20"><i class="ph ph-floppy-disk"></i></span>
            Salvar
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
