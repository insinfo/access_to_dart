{{=<% %>=}}
<div *ngIf="insideModal == false" class="page-header page-header-light shadow">
  <div class="page-header-content d-lg-flex">
    <h4 class="page-title mb-0">Módulo - <span class="fw-normal">Incluir <%namePascal%></span></h4>
  </div>
</div>

<div class="content">
  <div class="alert alert-info border-start border-info border-4 mb-3" *ngIf="validationHints.isNotEmpty">
    <strong>Regras migradas do formulario Access:</strong>
    <ul class="mb-0 mt-2">
      <li *ngFor="let hint of validationHints">{{ hint }}</li>
    </ul>
  </div>
  <div class="card">
    <div class="card-body">
      <form (ngSubmit)="salvar()" #formEntity="ngForm" novalidate>
        <div class="row">
<%#fields%>
          <div class="col-md-4 form-group mb-3">
            <label class="form-label"><%label%>:</label>
<%#isSingleSelect%>
            <select
              [ngModel]="readField('<%readKey%>')"
              (ngModelChange)="updateField('<%updateKey%>', $event)"
              ngControl="<%ngControl%>"
<%#isReadOnly%>
              disabled
<%/isReadOnly%>
<%#isRequired%>
              required
<%/isRequired%>
<%#title%>
              title="<%title%>"
<%/title%>
<%#selectSize%>
              size="<%selectSize%>"
<%/selectSize%>
              [class.is-invalid]="readFieldError('<%updateKey%>') != null"
              class="form-select">
              <option value="">Selecione <%label%></option>
<%#isDynamicSelect%>
              <option *ngFor="let option of lookupOptions('<%dynamicFieldKey%>')" [value]="option.value">{{ option.label }}</option>
<%/isDynamicSelect%>
<%#options%>
              <option value="<%value%>"><%label%></option>
<%/options%>
            </select>
<%/isSingleSelect%>
<%#isMultiValueSelect%>
            <div
              class="border rounded p-2"
<%#title%>
              title="<%title%>"
<%/title%>
              >
<%#isDynamicSelect%>
              <label class="form-check mb-1" *ngFor="let option of lookupOptions('<%dynamicFieldKey%>')">
                <input
                  class="form-check-input"
                  type="checkbox"
                  [checked]="isFieldOptionSelected('<%updateKey%>', option.value)"
                  (change)="toggleFieldSelection('<%updateKey%>', option.value, $event.target.checked)">
                <span class="form-check-label">{{ option.label }}</span>
              </label>
<%/isDynamicSelect%>
<%#options%>
              <label class="form-check mb-1">
                <input
                  class="form-check-input"
                  type="checkbox"
                  [checked]="isFieldOptionSelected('<%updateKey%>', '<%value%>')"
                  (change)="toggleFieldSelection('<%updateKey%>', '<%value%>', $event.target.checked)">
                <span class="form-check-label"><%label%></span>
              </label>
<%/options%>
            </div>
<%/isMultiValueSelect%>
<%#isCheckboxControl%>
            <div class="form-check pt-2">
              <input
                [ngModel]="readFieldBool('<%readKey%>')"
                (ngModelChange)="updateField('<%updateKey%>', $event)"
                ngControl="<%ngControl%>"
                type="checkbox"
<%#isReadOnly%>
                disabled
<%/isReadOnly%>
<%#title%>
                title="<%title%>"
<%/title%>
                class="form-check-input">
            </div>
<%/isCheckboxControl%>
<%#isTextAreaControl%>
            <textarea
              [ngModel]="readField('<%readKey%>')"
              (ngModelChange)="updateField('<%updateKey%>', $event)"
              ngControl="<%ngControl%>"
              rows="4"
<%#isReadOnly%>
              readonly
<%/isReadOnly%>
<%#isRequired%>
              required
<%/isRequired%>
<%#maxLength%>
              maxlength="<%maxLength%>"
<%/maxLength%>
<%#title%>
              title="<%title%>"
<%/title%>
              placeholder="<%label%>"
              [class.is-invalid]="readFieldError('<%updateKey%>') != null"
              class="form-control"></textarea>
<%/isTextAreaControl%>
<%#isPlainInput%>
            <input
              [ngModel]="readField('<%readKey%>')"
              (ngModelChange)="updateField('<%updateKey%>', $event)"
              ngControl="<%ngControl%>"
              type="<%inputType%>"
<%#isReadOnly%>
              readonly
<%/isReadOnly%>
<%#inputMode%>
              inputmode="<%inputMode%>"
<%/inputMode%>
<%#isRequired%>
              required
<%/isRequired%>
<%#maxLength%>
              maxlength="<%maxLength%>"
<%/maxLength%>
<%#title%>
              title="<%title%>"
<%/title%>
              placeholder="<%label%>"
              [class.is-invalid]="readFieldError('<%updateKey%>') != null"
              class="form-control">
<%/isPlainInput%>
            <div class="invalid-feedback d-block" *ngIf="readFieldError('<%updateKey%>') != null">
              {{ readFieldError('<%updateKey%>') }}
            </div>
          </div>
<%/fields%>
        </div>
        <div class="text-end mt-3">
          <button class="btn btn-primary btn-labeled btn-labeled-start" type="submit">
            <span class="btn-labeled-icon bg-black bg-opacity-20"><i class="ph ph-floppy-disk"></i></span>
            Salvar
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
